{
  "name": "@fastowl/backend",
  "version": "0.1.0",
  "description": "FastOwl Backend Server",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx watch src/index.ts",
    "build": "tsc && npm run build:copy-migrations",
    "build:copy-migrations": "node -e \"const fs=require('fs'),p=require('path');const src=p.resolve('src/db/migrations'),dst=p.resolve('dist/db/migrations');fs.rmSync(dst,{recursive:true,force:true});fs.cpSync(src,dst,{recursive:true});console.log('copied migrations to',dst)\"",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastowl/shared": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.103.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.18.2",
    "postgres": "^3.4.9",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.1",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
