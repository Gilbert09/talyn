# PostHog product analytics (optional). Analytics is inert unless the key is set.
# Project API key from PostHog → Project Settings.
NEXT_PUBLIC_POSTHOG_KEY=
# Ingestion host. US cloud: https://us.i.posthog.com · EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# logo.dev publishable token for provider logos (Claude / PostHog). A default
# is baked in; override here if you rotate the key.
NEXT_PUBLIC_LOGODEV_TOKEN=
